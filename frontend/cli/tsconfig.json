{
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "skipLibCheck": true,
    "erasableSyntaxOnly": true,
    "paths": {
      "@shared/*": ["../../shared/src/*"]
    }
  },
  "include": ["./**/*.ts", "../src/workers/**/*.ts", "../../shared/src/**/*.ts"]
}
